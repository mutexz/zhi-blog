---
import { sitePath } from '../utils/sitePath';
import { SITE_TITLE } from '../consts';

const year = new Date().getFullYear();

const navLinks = [
	{ label: '首页', href: sitePath('/') },
	{ label: '文章', href: sitePath('/articles/') },
	{ label: '笔记', href: sitePath('/notes/') },
	{ label: '关于', href: sitePath('/about/') },
];

const tags = ['软件测试', 'AI', 'LLM', '个人成长', '技术博客'];
---

<footer class="border-t border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-950">
	<div class="mx-auto max-w-5xl px-4 py-10 md:px-6">
		<div class="grid gap-8 sm:grid-cols-3">
			<div>
				<p class="font-serif text-base font-semibold text-zinc-900 dark:text-zinc-50">{SITE_TITLE}</p>
				<p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
					关注测试、AI 与个人成长，<br />用文字记录实践中的思考。
				</p>
			</div>

		<div>
			<p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">导航</p>
			<div class="mt-3 flex flex-wrap gap-x-4 gap-y-2">
				{navLinks.map(({ label, href }) => (
					<a href={href} class="text-sm text-zinc-600 transition-colors hover:text-emerald-700 dark:text-zinc-400 dark:hover:text-emerald-400">
						{label}
					</a>
				))}
			</div>
		</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">标签</p>
				<div class="mt-3 flex flex-wrap gap-2">
					{tags.map((tag) => (
						<span class="rounded-full border border-zinc-200 px-3 py-1 text-xs text-zinc-600 dark:border-zinc-700 dark:text-zinc-400">
							{tag}
						</span>
					))}
				</div>
			</div>
		</div>

		<div class="mt-8 flex flex-col items-center gap-2 border-t border-zinc-200 pt-6 text-xs text-zinc-400 dark:border-zinc-800 dark:text-zinc-500 sm:flex-row sm:justify-between">
			<p>&copy; {year} {SITE_TITLE}</p>
			<p>
				使用 <a href="https://astro.build" class="hover:text-emerald-700 dark:hover:text-emerald-400" target="_blank" rel="noopener noreferrer">Astro</a> 构建 · 部署于 <a href="https://pages.cloudflare.com" class="hover:text-emerald-700 dark:hover:text-emerald-400" target="_blank" rel="noopener noreferrer">Cloudflare Pages</a>
			</p>
		</div>
	</div>
</footer>
