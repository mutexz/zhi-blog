---
import { sitePath } from '../utils/sitePath';

const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 bg-white py-10 dark:border-zinc-800 dark:bg-zinc-950">
	<div
		class="mx-auto flex max-w-5xl flex-col gap-4 px-4 text-sm text-zinc-500 md:flex-row md:items-center md:justify-between md:px-6"
	>
		<p>© {year} 知行小站 · <a href={sitePath('/rss.xml')} class="cursor-pointer hover:underline">RSS</a></p>
		<p class="text-xs">使用 Astro 构建 · 内容来自 Markdown</p>
	</div>
</footer>
