---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import { absoluteUrl, sitePath } from '../utils/sitePath';

interface Props {
	title: string;
	description: string;
	/** 绝对路径，如 /favicon.svg */
	ogImagePath?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, ogImagePath = '/favicon.svg' } = Astro.props;
const ogImage = absoluteUrl(ogImagePath, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={sitePath('/favicon.svg')} />
<link rel="icon" href={sitePath('/favicon.ico')} />
<link rel="sitemap" href={sitePath('/sitemap-index.xml')} />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={absoluteUrl('/rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600;8..60,700&display=swap"
	rel="stylesheet"
/>

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="zh_CN" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL.href} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
