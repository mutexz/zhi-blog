---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { sitePath } from '../utils/sitePath';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = articles
	.filter((a) => a.data.featured)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const notes = (await getCollection('notes'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<SiteLayout title={`${SITE_TITLE} · 个人知识分享`} description={SITE_DESCRIPTION}>
	<section class="mx-auto max-w-5xl px-4 pb-16 pt-14 md:px-6 md:pt-20">
		<p class="text-sm font-medium tracking-widest text-emerald-700 dark:text-emerald-400">
			测试 · AI · 思考
		</p>
		<h1 class="mt-3 font-serif text-4xl font-semibold tracking-tight text-zinc-900 md:text-5xl dark:text-zinc-50">
			知行合一，以文字记录成长
		</h1>
		<p class="mt-5 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
			一个关注软件测试、AI 应用与个人成长的技术博客。长文沉淀方法论，短笔记捕捉灵感，在实践中持续学习与分享。
		</p>
		<div class="mt-8 flex flex-wrap gap-3">
			<a
				href={sitePath('/articles/')}
				class="inline-flex cursor-pointer items-center rounded-xl bg-zinc-900 px-5 py-3 text-sm font-semibold text-white outline-none ring-zinc-400 transition hover:bg-zinc-800 focus-visible:ring-2 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-white"
				>浏览文章</a
			>
			<a
				href={sitePath('/notes/')}
				class="inline-flex cursor-pointer items-center rounded-xl border border-zinc-300 bg-white px-5 py-3 text-sm font-semibold text-zinc-800 outline-none ring-zinc-400 transition hover:bg-zinc-50 focus-visible:ring-2 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:bg-zinc-800"
				>笔记流</a
			>
		</div>
	</section>

	<section class="border-t border-zinc-200 bg-white py-14 dark:border-zinc-800 dark:bg-zinc-950" aria-labelledby="feat">
		<div class="mx-auto max-w-5xl px-4 md:px-6">
			<div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
				<h2 id="feat" class="font-serif text-2xl font-semibold text-zinc-900 dark:text-zinc-50">精选长文</h2>
				<a
					href={sitePath('/articles/')}
					class="cursor-pointer text-sm font-medium text-emerald-700 hover:underline dark:text-emerald-400"
					>全部文章 →</a
				>
			</div>
		{featured.length > 0 ? (
			<div class="mt-8 grid gap-6 md:grid-cols-3">
				{featured.map((post) => (
					<article class="flex flex-col rounded-2xl border border-zinc-200 bg-zinc-50/50 p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/40">
						<p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
							{post.data.tags?.join(' · ') || '文章'}
							{post.data.readTime && ` · ${post.data.readTime}`}
						</p>
						<h3 class="mt-2 font-serif text-lg font-semibold text-zinc-900 dark:text-zinc-50">
							<a
								href={sitePath(`/articles/${post.id}/`)}
								class="cursor-pointer decoration-2 underline-offset-[0.28em] transition-colors hover:text-emerald-800 hover:underline hover:decoration-emerald-600 dark:hover:text-emerald-300 dark:hover:decoration-emerald-400"
							>
								{post.data.title}
							</a>
						</h3>
						<p class="mt-2 flex-1 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
							{post.data.description}
						</p>
						<p class="mt-4 text-xs text-zinc-500">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('zh-CN')}
							</time>
						</p>
					</article>
				))}
			</div>
		) : (
			<div class="mt-8 rounded-2xl border border-dashed border-zinc-300 bg-zinc-50/50 p-10 text-center dark:border-zinc-700 dark:bg-zinc-900/40">
				<p class="text-sm text-zinc-500 dark:text-zinc-400">文章正在酝酿中，敬请期待...</p>
			</div>
		)}
		</div>
	</section>

	<section class="border-t border-zinc-200 py-14 dark:border-zinc-800" aria-labelledby="notes">
		<div class="mx-auto max-w-5xl px-4 md:px-6">
			<div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
				<h2 id="notes" class="font-serif text-2xl font-semibold text-zinc-900 dark:text-zinc-50">笔记流</h2>
				<a
					href={sitePath('/notes/')}
					class="cursor-pointer text-sm font-medium text-emerald-700 hover:underline dark:text-emerald-400"
					>全部笔记 →</a
				>
			</div>
		{notes.length > 0 ? (
			<ul class="mt-8 divide-y divide-zinc-200 dark:divide-zinc-800">
				{notes.map((n) => (
					<li class="flex flex-col gap-1 py-5 md:flex-row md:items-baseline md:gap-6">
						<span class="shrink-0 text-xs font-medium text-zinc-500">
							<time datetime={n.data.pubDate.toISOString()}>{n.data.pubDate.toLocaleDateString('zh-CN')}</time>
						</span>
						<div>
							<a
								href={sitePath(`/notes/${n.id}/`)}
								class="cursor-pointer font-medium text-zinc-900 hover:underline dark:text-zinc-100"
							>
								{n.data.title}
							</a>
							<p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{n.data.description}</p>
						</div>
					</li>
				))}
			</ul>
		) : (
			<div class="mt-8 rounded-2xl border border-dashed border-zinc-300 bg-zinc-50/50 p-10 text-center dark:border-zinc-700 dark:bg-zinc-900/40">
				<p class="text-sm text-zinc-500 dark:text-zinc-400">笔记正在记录中，敬请期待...</p>
			</div>
		)}
		</div>
	</section>

	<section class="border-t border-zinc-200 bg-zinc-100/80 py-10 dark:border-zinc-800 dark:bg-zinc-900/50">
		<div class="mx-auto max-w-5xl px-4 md:px-6">
			<div class="flex flex-wrap items-center justify-center gap-3 text-sm">
				<span class="text-zinc-500 dark:text-zinc-400">关注方向：</span>
				<span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-1.5 font-medium text-emerald-800 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">
					<span class="text-base">🧪</span> 软件测试
				</span>
				<span class="inline-flex items-center gap-1.5 rounded-full border border-blue-200 bg-blue-50 px-4 py-1.5 font-medium text-blue-800 dark:border-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
					<span class="text-base">🤖</span> AI 与大模型
				</span>
				<span class="inline-flex items-center gap-1.5 rounded-full border border-amber-200 bg-amber-50 px-4 py-1.5 font-medium text-amber-800 dark:border-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
					<span class="text-base">💡</span> 个人感想
				</span>
			</div>
		</div>
	</section>
</SiteLayout>
