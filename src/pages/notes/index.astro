---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { sitePath } from '../../utils/sitePath';

const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SiteLayout title={`笔记 · ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main id="main" class="mx-auto max-w-3xl px-4 py-12 md:px-6 md:py-16">
		<h1 class="font-serif text-3xl font-semibold tracking-tight md:text-4xl">笔记流</h1>
		<p class="mt-3 text-zinc-600 dark:text-zinc-400">短内容、摘录与备忘。</p>

	{notes.length > 0 ? (
		<div class="mt-10 space-y-6">
			{notes.map((n) => (
				<article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
					<div class="flex flex-wrap items-center gap-2 text-xs text-zinc-500">
						<time datetime={n.data.pubDate.toISOString()}>{n.data.pubDate.toLocaleDateString('zh-CN')}</time>
						<span class="rounded-full bg-zinc-100 px-2 py-0.5 dark:bg-zinc-800">{n.data.noteType}</span>
					</div>
					<h2 class="mt-2 text-lg font-semibold">
						<a
							href={sitePath(`/notes/${n.id}/`)}
							class="cursor-pointer decoration-2 underline-offset-[0.28em] transition-colors hover:text-emerald-800 hover:underline hover:decoration-emerald-600 dark:hover:text-emerald-300 dark:hover:decoration-emerald-400"
						>
							{n.data.title}
						</a>
					</h2>
					<p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{n.data.description}</p>
				</article>
			))}
		</div>
	) : (
		<div class="mt-10 rounded-2xl border border-dashed border-zinc-300 p-12 text-center dark:border-zinc-700">
			<p class="text-lg font-medium text-zinc-500 dark:text-zinc-400">暂无笔记</p>
			<p class="mt-2 text-sm text-zinc-400 dark:text-zinc-500">灵感还在路上...</p>
		</div>
	)}
	</main>
</SiteLayout>
